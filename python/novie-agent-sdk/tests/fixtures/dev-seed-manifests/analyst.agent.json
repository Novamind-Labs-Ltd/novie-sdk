  "metadata": {
    "owner_team": "novie-core",
    "durability": "none",
    "protocol_mode": "stream",
    "role_description": "Turns user goals, project context, and research prompts into structured analysis artifacts.",
    "when_to_use": [
      "Requirements extraction, product scoping, stakeholder analysis, research framing, feasibility analysis, or report synthesis.",
      "Early planning stages where the platform needs a clear artifact before implementation."
    ],
    "when_not_to_use": [
      "Direct repository edits, GitHub operations, pull request creation, or task-bundle execution.",
      "Inspecting an already running plan or agent execution status."
    ],
    "handoff_contract": "Produces analysis artifacts for Planner, Task Splitter, or downstream review; does not execute repository changes.",
    "user_facing_aliases": [
      "requirements agent",
      "analyst agent",
      "research agent",
      "report agent"
    ],
    "artifact_output_type": "requirements_analysis",
    "analysis_modes": [
      "requirements",
      "research_report",
      "feasibility"
    ],
    "analysis_phases": [
      "discovery",
      "scoping",
      "validation",
      "reporting"
    ],
    "runtime_phases": [
      {
        "runtime_phase": "research_synthesize",
        "semantic_phase": "collecting_sources",
        "display_name": "Collecting sources"
      },
      {
        "runtime_phase": "condense",
        "semantic_phase": "condensing_evidence",
        "display_name": "Condensing evidence"
      },
      {
        "runtime_phase": "finalize",
        "semantic_phase": "finalizing_output",
        "display_name": "Finalizing output"
      }
    ],
    "stream_events": {
      "phase_change_event": "analyst_phase_change",
      "run_summary_event": "analyst_run_summary",
      "summary_fields": [
