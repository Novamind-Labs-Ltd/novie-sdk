{
  "$schema": "https://novie.dev/schemas/agent-manifest-v2.json",
  "agent_id": "task_splitter",
  "name": "Task Splitter",
  "version": "0.1.0",
  "kind": "expert_basic",
  "runtime": "external_a2a",
  "capabilities": [
    "task_decomposition",
    "issue_planning",
    "ticket_drafting"
  ],
  "capability_manifest": [
    {
      "capability_id": "agent.task_splitter.task_decomposition",
      "version": "0.1.0",
      "display_name": "Decompose Tasks",
      "description": "Break requirements analysis into implementation tasks.",
      "input_schema": {"type": "object"},
      "output_schema": {"type": "object"},
      "risk": "read",
      "side_effect": "none",
      "exec_kind": "async",
      "runtime_ref": "agent:task_splitter:task_decomposition",
      "tags": ["planning", "tasks"],
      "natural_language_aliases": ["拆任务", "task decomposition"],
      "idempotent": true,
      "expected_duration_class": "<1min",
      "consumes": ["requirements_analysis"],
      "provides": ["task_plan"],
      "execution_lane": "direct",
      "risk_class": "read_only",
      "governance": {
        "requires_plan_review": false,
        "requires_tracker_issue": false,
        "requires_human_gate": false
      }
    },
    {
      "capability_id": "agent.task_splitter.issue_planning",
      "version": "0.1.0",
      "display_name": "Plan Issues",
      "description": "Convert scoped work into reviewable issue-sized implementation units.",
      "input_schema": {"type": "object"},
      "output_schema": {"type": "object"},
      "risk": "read",
      "side_effect": "none",
      "exec_kind": "async",
      "runtime_ref": "agent:task_splitter:issue_planning",
      "tags": ["planning", "issues"],
      "natural_language_aliases": ["规划 issue", "issue planning"],
      "idempotent": true,
      "expected_duration_class": "<1min",
      "provides": ["issue_plan"],
      "execution_lane": "direct",
      "risk_class": "read_only",
      "governance": {
        "requires_plan_review": false,
        "requires_tracker_issue": false,
        "requires_human_gate": false
      }
    },
    {
      "capability_id": "agent.task_splitter.ticket_drafting",
      "version": "0.2.0",
      "display_name": "Draft PMS Tickets",
      "description": "Convert a scoped requirements-analysis-backed task plan into a WorkItemDraftGraph to be written into the PMS Backlog.",
      "input_schema": {"type": "object"},
      "output_schema": {"type": "object"},
      "risk": "read",
      "side_effect": "none",
      "exec_kind": "async",
      "runtime_ref": "agent:task_splitter:ticket_drafting",
      "tags": ["work_item_draft_graph", "pms-first"],
      "natural_language_aliases": ["拆 ticket", "生成 ticket", "ticket drafting"],
      "idempotent": true,
      "expected_duration_class": "<1min",
      "consumes": ["task_plan", "requirements_analysis"],
      "provides": ["work_item_draft_graph"],
      "execution_lane": "direct",
      "risk_class": "read_only",
      "governance": {
        "requires_plan_review": false,
        "requires_tracker_issue": false,
        "requires_human_gate": false
      }
    }
  ],
  "declared_gates": [],
  "protocol_mode": "stream",
  "endpoint": "http://task-splitter:8012",
  "execution": {
    "expected_duration_seconds": 60,
    "max_duration_seconds": 180,
    "idempotent": true,
    "supports_cancel": false,
    "supports_resume": false,
    "emits_events": false,
    "durability": "none"
  },
  "required_secrets": [],
  "supports_streaming": true,
  "sandbox_isolation": "shared",
  "metadata": {
    "owner_team": "novie-core",
    "durability": "none",
    "protocol_mode": "stream",
    "role_description": "Converts scoped requirements, designs, or analysis artifacts into WorkItemDraftGraphs to be written into the PMS Backlog.",
    "when_to_use": [
      "Build or sprint-planning tasks that need decomposition before tickets can be created.",
      "Producing a WorkItemDraftGraph for the platform to ingest into PMS Backlog."
    ],
    "when_not_to_use": [
      "Producing final code changes, editing repositories, creating pull requests, or answering status questions.",
      "Raw research or requirements clarification before a scoped artifact exists."
    ],
    "handoff_contract": "Consumes scoped artifacts and produces WorkItemDraftGraph; platform TicketDraftIngestionService writes the drafts into PMS Backlog. Each ticket then enters the standard Backlog -> Todo -> execution flow per ExecutionPolicy.",
    "user_facing_aliases": [
      "task splitting agent",
      "decomposition agent",
      "ticket drafting agent"
    ],
    "artifact_input_types": [
      "prd",
      "design",
      "analysis",
      "requirements_analysis"
    ],
    "artifact_output_type": "work_item_draft_graph",
    "input_schema": "schemas/input.schema.json",
    "output_schema": "schemas/output.schema.json"
  }
}
